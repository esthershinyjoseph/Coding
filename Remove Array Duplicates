int removeDuplicates(int *nums, int numsSize){
int i, j=1,flag=1;
int curr = nums[0];
printf("Numsize: %d\n",numsSize);
if (numsSize <=2)
    return numsSize;
for (i=1;i<numsSize;i++)
{
    if(nums[i]== curr)
    {
               
        flag++;
        if (flag <=2)
        {
            nums [j] = nums[i];
            j++;
        }
    }
    else 
    {
        curr = nums[i];
        flag = 1;
        nums[j]=nums[i];
        j++;
      
    }
   
}
return j;
}
